{
  "mcpServers": {
    "aspire": {
      "type": "local",
      "command": "aspire",
      "args": [
        "agent",
        "mcp"
      ],
      "env": {
        "DOTNET_ROOT": "${DOTNET_ROOT}"
      },
      "tools": ["*"]
    },
    "EXAMPLE-trello": {
      "command": "npx",
      "args": [
        "-y",
        "@trello/mcp-server"
      ],
      "env": {
        "TRELLO_API_KEY": "${TRELLO_API_KEY}",
        "TRELLO_TOKEN": "${TRELLO_TOKEN}"
      }
    }
  }
}
