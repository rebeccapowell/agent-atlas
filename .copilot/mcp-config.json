{
  "mcpServers": {
    "aspire": {
      "type": "local",
      "command": "aspire",
      "args": [
        "mcp",
        "start"
      ],
      "env": {
        "DOTNET_ROOT": "${DOTNET_ROOT}"
      },
      "tools": ["*"]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp"
      ]
    }
  }
}
