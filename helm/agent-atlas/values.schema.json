{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Atlas Helm Chart Values",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "tag": { "type": "string" }
      },
      "required": ["repository", "pullPolicy"]
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "automount": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "targetPort": { "type": "integer", "minimum": 1, "maximum": 65535 }
      },
      "required": ["type", "port", "targetPort"]
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "host": { "type": "string" },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": { "type": "string" },
                    "pathType": {
                      "type": "string",
                      "enum": ["Prefix", "Exact", "ImplementationSpecific"]
                    }
                  },
                  "required": ["path", "pathType"]
                }
              }
            },
            "required": ["host", "paths"]
          }
        },
        "tls": { "type": "array" }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "limits": { "type": "object" },
        "requests": { "type": "object" }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "atlas": {
      "type": "object",
      "properties": {
        "catalogPath": { "type": "string" },
        "catalogStrict": { "type": "boolean" },
        "oidc": {
          "type": "object",
          "properties": {
            "issuer": { "type": "string" },
            "audience": { "type": "string" },
            "allowedIssuers": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "platformPermissions": {
          "type": "object",
          "properties": {
            "claim": { "type": "string" },
            "search": { "type": "string" },
            "execute": { "type": "string" },
            "executeWrite": { "type": "string" }
          }
        },
        "execLimits": {
          "type": "object",
          "properties": {
            "maxSteps": { "type": "integer", "minimum": 1 },
            "maxCalls": { "type": "integer", "minimum": 1 },
            "maxSeconds": { "type": "integer", "minimum": 1 },
            "maxBytes": { "type": "integer", "minimum": 1 },
            "maxResponseBytes": { "type": "integer", "minimum": 1 },
            "maxConcurrency": { "type": "integer", "minimum": 1 }
          }
        }
      },
      "required": ["catalogPath"]
    },
    "catalog": {
      "type": "object",
      "properties": {
        "configMap": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "name": { "type": "string" }
          }
        },
        "pvc": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "claimName": { "type": "string" }
          }
        },
        "gitSync": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "image": { "type": "string" },
            "repo": { "type": "string" },
            "branch": { "type": "string" },
            "period": { "type": "string" },
            "depth": { "type": "integer", "minimum": 1 },
            "resources": { "type": "object" }
          }
        }
      }
    },
    "redis": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "host": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "secretName": { "type": "string" },
        "secretKey": { "type": "string" }
      }
    },
    "extraEnv": {
      "type": "array",
      "items": { "type": "object" }
    },
    "extraVolumes": {
      "type": "array",
      "items": { "type": "object" }
    },
    "extraVolumeMounts": {
      "type": "array",
      "items": { "type": "object" }
    }
  }
}
